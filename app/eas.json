{
  "cli": {
    "version": ">= 18.13.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_REVENUECAT_IOS_API_KEY": "your_revenuecat_ios_api_key"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_REVENUECAT_IOS_API_KEY": "your_revenuecat_ios_api_key"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_REVENUECAT_IOS_API_KEY": "your_revenuecat_ios_api_key"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
